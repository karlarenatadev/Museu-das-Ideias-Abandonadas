# ============================================================
# MUSEU DAS IDEIAS ABANDONADAS - Backend
# ============================================================

# Servidor
PORT=3001
NODE_ENV=development
LOG_LEVEL=info
FRONTEND_URL=http://localhost:5173

# IA
# AI_PROVIDER pode ser "gemini" ou "openrouter".
AI_PROVIDER=gemini

# Gemini
GEMINI_API_KEY=sua_chave_gemini_aqui

# OpenRouter
OPENROUTER_API_KEY=sua_chave_openrouter_aqui
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Supabase
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# Desenvolvimento sem Supabase Auth
DEV_USER_ID=dev-user

# SMTP
# Deixe em branco para desabilitar envio de e-mails.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_de_app
MAIL_FROM="Museu das Ideias Abandonadas <seu_email@gmail.com>"
