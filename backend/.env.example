# ============================================
# MUSEU DAS IDEIAS ABANDONADAS - Backend
# Arquivo de Configuração de Variáveis de Ambiente
# ============================================

# Porta do servidor (padrão: 3001)
PORT=3001

# Ambiente de execução (development, production)
NODE_ENV=development

# Chave da API do Google Gemini
# Obtenha sua chave em: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=sua_chave_api_aqui

# ============================================
# INSTRUÇÕES:
# 1. Copie este arquivo e renomeie para .env
# 2. Substitua 'sua_chave_api_aqui' pela sua chave real do Gemini
# 3. Nunca commite o arquivo .env no Git!
# ============================================
