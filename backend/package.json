{
  "name": "museu-das-ideias-backend",
  "version": "1.0.0",
  "description": "Backend API para o Museu das Ideias Abandonadas",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "build": "cd ../frontend && npm run build && cd ../backend",
    "deploy": "npm run build && npm start",
    "test": "node test-idea-service.js",
    "seed:ideas": "node src/seeds/seedInitialIdeas.js"
  },
  "keywords": ["express", "gemini", "ai", "backend", "api"],
  "author": "Backend Sênior",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@supabase/supabase-js": "^2.106.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "nodemailer": "^6.9.15",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0"
  }
}
